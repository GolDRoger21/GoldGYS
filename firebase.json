{
  "firestore": {
    "rules": "firestore/firestore.rules",
    "indexes": "firestore/firestore.indexes.json"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "public",
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      {
        "source": "/sitemap.xml",
        "function": "sitemap"
      },
      {
        "source": "/dashboard",
        "destination": "/pages/dashboard.html"
      },
      {
        "source": "/konular",
        "destination": "/pages/konular.html"
      },
      {
        "source": "/konu/*/test-coz/**",
        "destination": "/pages/test.html"
      },
      {
        "source": "/konu/**",
        "destination": "/pages/konu.html"
      },
      {
        "source": "/denemeler",
        "destination": "/pages/denemeler.html"
      },
      {
        "source": "/deneme/**",
        "destination": "/pages/deneme.html"
      },
      {
        "source": "/analiz",
        "destination": "/pages/analiz.html"
      },
      {
        "source": "/profil",
        "destination": "/pages/profil.html"
      },
      {
        "source": "/yanlislarim",
        "destination": "/pages/yanlislarim.html"
      },
      {
        "source": "/favoriler",
        "destination": "/pages/favoriler.html"
      },
      {
        "source": "/yardim",
        "destination": "/pages/yardim.html"
      },
      {
        "source": "/yasal",
        "destination": "/pages/yasal.html"
      },
      {
        "source": "/pending-approval",
        "destination": "/pages/pending-approval.html"
      },
      {
        "source": "/test",
        "destination": "/pages/test.html"
      },
      {
        "source": "/report",
        "destination": "/pages/report.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|avif|ico|eot|otf|ttf|ttc|woff|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/serviceAccountKey.json",
      "**/*.log",
      "**/.DS_Store"
    ]
  },
  "emulators": {
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true
    },
    "singleProjectMode": true
  }
}
