{
  "name": "goldgys",
  "version": "1.0.0",
  "scripts": {
    "build": "node scripts/analyze-assets.cjs",
    "check:assets": "node scripts/analyze-assets.cjs --analyze",
    "check:budgets": "node scripts/analyze-assets.cjs --check-budgets",
    "check:syntax": "node scripts/check-js-syntax.cjs",
    "audit:queries": "node scripts/audit-firestore-queries.cjs",
    "audit:content-model": "node scripts/audit-content-model.cjs",
    "audit:content-model:strict": "node scripts/audit-content-model.cjs --strict",
    "test:content-model:contract": "node scripts/test-content-model-contract.cjs",
    "release:checklist": "node scripts/create-release-checklist.cjs",
    "release:checklist:meta": "node scripts/fill-release-checklist-meta.cjs",
    "release:checklist:budget": "node scripts/fill-release-checklist-budget.cjs",
    "release:checklist:guardrails": "node scripts/fill-release-checklist-guardrails.cjs",
    "release:checklist:guardrails:full": "node scripts/fill-release-checklist-guardrails.cjs --with-rules",
    "release:checklist:cwv": "node scripts/fill-release-checklist-cwv.cjs",
    "release:checklist:cwv:encode": "node scripts/encode-cwv-snapshot.cjs",
    "release:checklist:quality": "node scripts/fill-release-checklist-quality.cjs",
    "release:checklist:quality:e2e": "node scripts/fill-release-checklist-quality.cjs --with-e2e",
    "release:checklist:phase-gates": "node scripts/fill-release-checklist-phase-gates.cjs",
    "release:checklist:decision": "node scripts/fill-release-checklist-decision.cjs",
    "release:checklist:refresh": "npm run release:checklist && npm run release:checklist:meta && npm run release:checklist:budget && npm run release:checklist:cwv && npm run release:checklist:guardrails && npm run release:checklist:quality && npm run release:checklist:phase-gates && npm run release:checklist:decision",
    "release:checklist:refresh:full": "npm run release:checklist && npm run release:checklist:meta && npm run release:checklist:budget && npm run release:checklist:cwv && npm run release:checklist:guardrails:full && npm run release:checklist:quality:e2e && npm run release:checklist:phase-gates && npm run release:checklist:decision",
    "test:rules": "node scripts/run-rules-tests.cjs",
    "test:e2e:smoke": "firebase emulators:exec --only hosting \"playwright test tests/e2e/smoke.spec.js --project=chromium\"",
    "test:e2e:smoke:core": "firebase emulators:exec --only hosting \"playwright test tests/e2e/smoke.spec.js --project=chromium --grep-invert @optional\"",
    "test:e2e:smoke:auth": "firebase emulators:exec --only hosting \"playwright test tests/e2e/smoke.spec.js --project=chromium --grep @optional\"",
    "test:e2e:smoke:headed": "firebase emulators:exec --only hosting \"playwright test tests/e2e/smoke.spec.js --project=chromium --headed\"",
    "test:e2e:auth:prepare": "node scripts/prepare-e2e-auth-state.cjs",
    "test:e2e:auth:encode:user": "node scripts/encode-e2e-auth-state.cjs --in=tests/e2e/.auth/user.json",
    "test:e2e:auth:encode:admin": "node scripts/encode-e2e-auth-state.cjs --in=tests/e2e/.auth/admin.json",
    "test:e2e:auth:capture:user": "firebase emulators:exec --only hosting \"node scripts/capture-e2e-storage-state.cjs --role=user --out=tests/e2e/.auth/user.json\"",
    "test:e2e:auth:capture:admin": "firebase emulators:exec --only hosting \"node scripts/capture-e2e-storage-state.cjs --role=admin --out=tests/e2e/.auth/admin.json\"",
    "ci:checks": "npm run check:syntax && npm run check:budgets && npm run audit:queries",
    "ci:full": "npm run ci:checks && npm run test:rules",
    "ci:quick": "npm run check:syntax && npm run audit:queries && npm run audit:content-model && npm run test:content-model:contract"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@playwright/test": "^1.54.2",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.6.0",
    "firebase-tools": "^14.1.0"
  }
}
