rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function hasTokenBool(key) {
      return signedIn() &&
        request.auth.token.keys().hasAny([key]) &&
        request.auth.token[key] == true;
    }

    function tokenRoleIs(role) {
      return signedIn() &&
        request.auth.token.keys().hasAny(['role']) &&
        request.auth.token.role == role;
    }

    function tokenRoleIn(roles) {
      return signedIn() &&
        request.auth.token.keys().hasAny(['role']) &&
        roles.hasAny([request.auth.token.role]);
    }
    function profileRole() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return signedIn() && (
        hasTokenBool('admin') ||
        tokenRoleIs('admin') ||
        profileRole() == 'admin'
      );
    }

    function isEditor() {
      return signedIn() && (
        hasTokenBool('admin') ||
        hasTokenBool('editor') ||
        tokenRoleIn(['admin', 'editor']) ||
        profileRole() == 'admin' ||
        profileRole() == 'editor'
      );
    }

    match /stats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || isAdmin();

      allow create: if isSelf(uid)
        && request.resource.data.role == 'user'
        && request.resource.data.status == 'pending';

      allow update: if isAdmin() || (
        isSelf(uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'photoURL',
          'email',
          'lastLoginAt',
          'updatedAt',
          'ad',
          'soyad',
          'phone',
          'title',
          'targetExam'
        ])
      );

      allow delete: if isAdmin();

      match /{subcollection=**} {
        allow read, write: if isSelf(uid) || isAdmin();
      }
    }

    match /system/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /topics/{topicId} {
      allow read: if true;
      allow create, update, delete: if isEditor();

      match /lessons/{lessonId} {
        allow read: if signedIn();
        allow write: if isEditor();
      }
    }

    match /exams/{examId} {
      allow read: if signedIn();
      allow write: if isEditor();
    }

    match /questions/{questionId} {
      allow read: if signedIn();
      allow write: if isEditor();
    }

    match /reports/{reportId} {
      allow create: if false;
      allow read, update, delete: if isEditor();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
